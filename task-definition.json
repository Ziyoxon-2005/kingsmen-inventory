{
    "family": "kingsmen-task",
    "networkMode": "awsvpc",
    "requiresCompatibilities": ["FARGATE"],
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::521106216357:role/ecsTaskExecutionRole",
    "taskRoleArn": "arn:aws:iam::521106216357:role/ecsTaskRole",
    "containerDefinitions": [
        {
            "name": "kingsmen-container",
            "image": "public.ecr.aws/docker/library/python:3.8-slim",
            "cpu": 256,
            "memory": 512,
            "portMappings": [
                {
                    "containerPort": 8000,
                    "hostPort": 8000,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "DJANGO_SETTINGS_MODULE",
                    "value": "inventoryproject.settings"
                },
                {
                    "name": "DJANGO_ALLOWED_HOSTS",
                    "value": "*"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/kingsmen",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "ecs",
                    "awslogs-create-group": "true"
                }
            },
            "command": [
                "sh",
                "-c",
                "pip install -r requirements.txt && python manage.py migrate && python manage.py runserver 0.0.0.0:8000"
            ]
        }
    ]
} 