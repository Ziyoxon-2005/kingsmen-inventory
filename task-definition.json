{
    "family": "kingsmen-inventory",
    "networkMode": "awsvpc",
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::521106216357:role/ecsTaskExecutionRole",
    "taskRoleArn": "arn:aws:iam::521106216357:role/ecsTaskRole",
    "containerDefinitions": [
        {
            "name": "kingsmen-container",
            "image": "521106216357.dkr.ecr.us-east-1.amazonaws.com/kingsmen-inventory:latest",
            "cpu": 256,
            "memory": 512,
            "portMappings": [
                {
                    "containerPort": 8000,
                    "hostPort": 8000,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "DJANGO_SETTINGS_MODULE",
                    "value": "inventoryproject.settings"
                },
                {
                    "name": "DEBUG",
                    "value": "False"
                },
                {
                    "name": "ALLOWED_HOSTS",
                    "value": "*"
                }
            ],
            "secrets": [
                {
                    "name": "DJANGO_SECRET_KEY",
                    "valueFrom": "arn:aws:secretsmanager:us-east-1:521106216357:secret:DJANGO_SECRET_KEY"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/kingsmen-inventory",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "ecs",
                    "awslogs-create-group": "true"
                }
            },
            "healthCheck": {
                "command": [
                    "CMD-SHELL",
                    "python manage.py check || exit 1"
                ],
                "interval": 30,
                "timeout": 5,
                "retries": 3,
                "startPeriod": 60
            },
            "command": [
                "sh",
                "-c",
                "python manage.py migrate && python manage.py collectstatic --noinput && gunicorn inventoryproject.wsgi:application --bind 0.0.0.0:8000"
            ]
        }
    ]
} 